# Server Configuration
PORT=3001
NODE_ENV=production

# Web3Forms Configuration
# Get your free Web3Forms Access Key from https://web3forms.com
# Free tier: 250 submissions/month, no credit card required
WEB3FORMS_ACCESS_KEY=your_web3forms_access_key_here

# Gemini API Configuration (Optional - if you add AI features later)
# Get free API key from https://ai.google.dev
# Free tier: 15 requests/minute for text models
GEMINI_API_KEY=your_gemini_api_key_here
