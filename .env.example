# Server Configuration
PORT=3001
NODE_ENV=production

# Formspree Configuration
# Get your free Formspree ID from https://formspree.io
# Free tier: 50 submissions/month, no credit card required
FORMSPREE_ID=your_formspree_id_here

# Gemini API Configuration (Optional - if you add AI features later)
# Get free API key from https://ai.google.dev
# Free tier: 15 requests/minute for text models
GEMINI_API_KEY=your_gemini_api_key_here
